y = df_names_var_te_$title) +
scale_x_continuous(limits = c(2016.5, 2025), breaks = seq(2017, 2024, by = 1)) +
theme_minimal_hgrid() +
geom_hline(data=data_filter, mapping=aes(yintercept=median(std_value,na.rm = TRUE)), color="red") +
geom_text(x=2025, y=max(data_filter$std_value,na.rm=TRUE), label="| P50 (2017-2024)", color = 'red', size=4,hjust=1) +
geom_text(x=2025, y=median(data_filter$std_value,na.rm = TRUE), label=paste0('                ',round(median(data_filter$std_value,na.rm = TRUE),2)), color = 'red', size=4) +
geom_text(x=2024.5, y=max(data_filter$std_value,na.rm=TRUE), label="| P50 año", color = 'black',hjust=1) +
coord_flip()
plot
